import tkinter as tk
import random
import math
from dataclasses import dataclass
from typing import List

@dataclass
class Position:
    x: float
    y: float

class RoboticDog:
    """
    A simulated Robotic Security Dog designed for industrial facilities.
    Includes advanced patrol logic, pursuit protocols, and self-docking AI.
    """
    
    def __init__(self, name="Aegis-DH"):
        self.name = name
        self.pos = Position(100.0, 100.0) 
        self.battery = 100.0
        self.orientation = 0.0  
        self.state = "IDLE"  # IDLE, PATROLLING, CHASING, GOING_TO_CHARGE, CHARGING
        self.target = None
        
        # Industrial Specs
        self.WALK_SPEED = 1.8
        self.RUN_SPEED = 5.5
        self.DETECTION_RADIUS = 150.0 
        self.CATCH_RADIUS = 20.0
        
        # Charging Station Logic
        self.CHARGING_STATION = Position(50.0, 50.0)
        self.LOW_BATTERY_THRESHOLD = 20.0
        
        # Patrol Route (Industrial Checkpoints)
        self.checkpoints = [
            Position(100, 100), Position(500, 100), 
            Position(500, 300), Position(100, 300)
        ]
        self.current_waypoint_idx = 0
        
    def log(self, message: str):
        print(f"[{self.name}] ({self.state}) - {message}")

    def move_to(self, target_x: float, target_y: float, speed_mode: str = "WALK"):
        dx = target_x - self.pos.x
        dy = target_y - self.pos.y
        distance = math.sqrt(dx**2 + dy**2)
        
        if distance < 3.0:
            return True # Arrived
            
        current_speed = self.RUN_SPEED if speed_mode == "RUN" else self.WALK_SPEED
        self.orientation = math.degrees(math.atan2(dy, dx))
        
        # Legged locomotion simulation (slight swaying)
        sway = math.sin(time_counter * 0.5) * 0.5 if speed_mode == "WALK" else 0
        
        self.pos.x += (dx / distance) * current_speed
        self.pos.y += (dy / distance) * current_speed + sway
        
        # Battery consumption logic
        self.battery -= 0.025 if speed_mode == "RUN" else 0.01
        return False

    def scan_for_thief(self, entities: List[dict]):
        for entity in entities:
            if entity.get("type") == "THIEF" and not entity.get("caught"):
                dx = entity["pos"].x - self.pos.x
                dy = entity["pos"].y - self.pos.y
                dist = math.sqrt(dx**2 + dy**2)
                
                if dist <= self.DETECTION_RADIUS:
                    self.target = entity
                    if self.state != "CHASING":
                        self.log("INTRUSION DETECTED: Perimeter Breach at Industrial Zone.")
                        self.state = "CHASING"
                    return True
        return False

    def apprehend(self):
        self.state = "NEUTRALIZING"
        self.log("Target cornered. Activating Siren and Lockdown notification.")
        if self.target:
            self.target["caught"] = True
        self.state = "IDLE"
        self.target = None

    def update(self, environment_entities: List[dict]):
        # 1. CRITICAL OVERRIDE: Check if battery is low
        if self.battery < self.LOW_BATTERY_THRESHOLD and self.state not in ["GOING_TO_CHARGE", "CHARGING"]:
            self.log("CRITICAL: Low Power. Returning to base.")
            self.state = "GOING_TO_CHARGE"

        # 2. STATE MACHINE LOGIC
        if self.state == "GOING_TO_CHARGE":
            arrived = self.move_to(self.CHARGING_STATION.x, self.CHARGING_STATION.y, "WALK")
            if arrived:
                self.log("Docked successfully. Commencing rapid charge.")
                self.state = "CHARGING"
        
        elif self.state == "CHARGING":
            self.battery += 0.5  # Rapid charge logic
            if self.battery >= 100:
                self.battery = 100
                self.log("Power Restored. Resuming Facility Surveillance.")
                self.state = "IDLE"

        elif self.state == "IDLE":
            if not self.scan_for_thief(environment_entities):
                self.state = "PATROLLING"
        
        elif self.state == "PATROLLING":
            target_pt = self.checkpoints[self.current_waypoint_idx]
            arrived = self.move_to(target_pt.x, target_pt.y, "WALK")
            
            if arrived:
                self.current_waypoint_idx = (self.current_waypoint_idx + 1) % len(self.checkpoints)
            
            self.scan_for_thief(environment_entities)

        elif self.state == "CHASING":
            if self.target and not self.target.get("caught"):
                target_pos = self.target["pos"]
                dist = math.sqrt((target_pos.x - self.pos.x)**2 + (target_pos.y - self.pos.y)**2)
                
                if dist <= self.CATCH_RADIUS:
                    self.apprehend()
                else:
                    self.move_to(target_pos.x, target_pos.y, "RUN")
                    self.target["pos"].x += random.uniform(-3, 1)
                    self.target["pos"].y += random.uniform(-1, 1)
            else:
                self.state = "IDLE"

time_counter = 0

class RoboDogVisualizer:
    def __init__(self, root):
        self.root = root
        self.root.title("Daiwa House Industrial Security Simulation")
        
        # Grid/Industrial Floor Canvas
        self.canvas = tk.Canvas(root, width=600, height=400, bg="#2c3e50", highlightthickness=0)
        self.canvas.pack(pady=10)
        
        self.status_label = tk.Label(root, text="System: Monitoring Facility", fg="#2ecc71", bg="#1a1a1a", font=("Segoe UI", 11, "bold"))
        self.status_label.pack(fill=tk.X)
        
        self.dog = RoboticDog()
        self.thief = {"type": "THIEF", "pos": Position(550.0, 350.0), "caught": False}
        self.entities = [self.thief]
        
        self.update_loop()

    def draw_environment(self):
        # Draw floor grid
        for i in range(0, 600, 50):
            self.canvas.create_line(i, 0, i, 400, fill="#34495e")
        for i in range(0, 400, 50):
            self.canvas.create_line(0, i, 600, i, fill="#34495e")
            
        # Draw Patrol Checkpoints
        for cp in self.dog.checkpoints:
            self.canvas.create_oval(cp.x-3, cp.y-3, cp.x+3, cp.y+3, fill="#95a5a6")
            
        # Draw Charging Station
        cs = self.dog.CHARGING_STATION
        self.canvas.create_rectangle(cs.x-15, cs.y-15, cs.x+15, cs.y+15, outline="#f1c40f", width=2)
        self.canvas.create_text(cs.x, cs.y-25, text="BASE", fill="#f1c40f", font=("Arial", 8, "bold"))

    def draw_dog(self):
        x, y = self.dog.pos.x, self.dog.pos.y
        
        # Sensor Sweep Arc (Only if not in charging states)
        if self.dog.state not in ["GOING_TO_CHARGE", "CHARGING"]:
            angle = self.dog.orientation
            self.canvas.create_arc(x-self.dog.DETECTION_RADIUS, y-self.dog.DETECTION_RADIUS, 
                                    x+self.dog.DETECTION_RADIUS, y+self.dog.DETECTION_RADIUS, 
                                    start=-angle-30, extent=60, outline="#2ecc71", style=tk.ARC)
        
        # Robot Body
        r = 12
        color = "#f39c12" if self.dog.state == "CHARGING" else "#ecf0f1"
        self.canvas.create_oval(x-r, y-r, x+r, y+r, fill=color, outline="#bdc3c7", width=2)
        
        # Direction Vector
        angle_rad = math.radians(self.dog.orientation)
        nx, ny = x + math.cos(angle_rad)*18, y + math.sin(angle_rad)*18
        self.canvas.create_line(x, y, nx, ny, fill="#e74c3c", width=2)

    def draw_thief(self):
        if not self.thief["caught"]:
            tx, ty = self.thief["pos"].x, self.thief["pos"].y
            self.canvas.create_rectangle(tx-10, ty-10, tx+10, ty+10, fill="#c0392b", outline="black")
            self.canvas.create_text(tx, ty-20, text="INTRUDER", fill="#ff7675", font=("Arial", 9, "bold"))

    def update_loop(self):
        global time_counter
        time_counter += 1
        
        self.canvas.delete("all")
        self.draw_environment()
        
        self.dog.update(self.entities)
        self.draw_thief()
        self.draw_dog()
        
        # Dynamic Status Colors
        if self.dog.state == "CHASING":
            color = "#e74c3c"
        elif self.dog.state == "CHARGING":
            color = "#f1c40f"
        elif self.dog.state == "GOING_TO_CHARGE":
            color = "#e67e22"
        else:
            color = "#2ecc71"
            
        status = f" FACILITY GUARD | STATUS: {self.dog.state.replace('_', ' ')} | ENERGY: {int(self.dog.battery)}%"
        self.status_label.config(text=status, fg=color)
        
        if self.thief["caught"]:
            self.canvas.create_text(300, 200, text="THIEF DETECTED & NEUTRALIZED", fill="#f1c40f", font=("Courier", 20, "bold"))
            self.canvas.create_text(300, 230, text="Authorities Notified - Lockdown Active", fill="white", font=("Courier", 10))
        
        self.root.after(30, self.update_loop)

if __name__ == "__main__":
    root = tk.Tk()
    root.configure(bg="#1a1a1a")
    app = RoboDogVisualizer(root)
    root.mainloop()
